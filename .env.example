# ─────────────────────────────────────────────────────────────────────────────
# IVA Sync — variables de entorno.
# Copiar a .env y rellenar. NUNCA commitear .env (ya esta en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ───────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_NAME=iva_sync
DB_USER=root
DB_PASS=

# ── Buzón IMAP del contribuyente ────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_FLAGS=/imap/ssl
IMAP_USERNAME=correo@ejemplo.com
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# ── Contribuyente (receptor) ────────────────────────────────────────────────
# Multiple cedulas separadas por coma (util para contadores)
RECEPTOR_CEDULAS=
STRICT_RECEPTOR=true

# ── Hacienda / TRIBU-CR ─────────────────────────────────────────────────────
HACIENDA_ENV=sandbox                    # sandbox | prod
HACIENDA_USERNAME=
HACIENDA_PASSWORD=
HACIENDA_CERT_PATH=                     # ruta absoluta al .p12 BCCR
HACIENDA_CERT_PASSWORD=
HACIENDA_AUTO_ACCEPT=false

# ── Seguridad ───────────────────────────────────────────────────────────────
# Token aleatorio para firmar sesiones. Generar con: openssl rand -hex 32
APP_SECRET=
FORCE_HTTPS=true
AUTH_ENABLED=true

# ── Log ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info                          # debug | info | warn | error
LOG_PATH=logs/app.log
